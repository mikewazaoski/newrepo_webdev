# Copy these into Railway → your APP service → Variables
# Use "Add variable reference" for DATABASE_URL (do not paste 127.0.0.1 or @mysql: Docker URLs)

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change_this_to_a_long_random_string
DEFAULT_URI=https://newrepowebdev-production.up.railway.app
TRUSTED_PROXIES=REMOTE_ADDR
DATABASE_URL=${{MySQL.MYSQL_URL}}

# Optional: create admin on deploy (matches login email you use)
ADMIN_EMAIL=admin@petpantry.com
ADMIN_PASSWORD=your_secure_password
ADMIN_USERNAME=admin
ADMIN_NAME=Administrator

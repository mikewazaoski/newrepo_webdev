# Copy to .env and fill in your local values (never commit .env)
# Railway/Docker: set DATABASE_URL=${{MySQL.MYSQL_URL}} on the app service; bin/railway-env.php writes .env at startup.
# https://symfony.com/doc/current/configuration/secrets.html

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_a_random_secret
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Local Symfony CLI (host machine)
DATABASE_URL="mysql://pets_user:pets_password@127.0.0.1:3307/pets_db?serverVersion=8.0&charset=utf8mb4"
# Docker Compose app container uses host "mysql" — see docker-compose.yaml and DOCKER.md
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

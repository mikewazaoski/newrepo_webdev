{% extends 'base_landing.html.twig' %}

{% block title %}Login - The Pet Pantry{% endblock %}

{% block body %}
<style>
    body {
        background: url('{{ asset('image/doggos.png') }}') no-repeat center center/cover;
        background-attachment: fixed;
        min-height: 100vh;
        font-family: 'Poppins', sans-serif;
    }

    .login-overlay {
        background: rgba(139, 94, 60, 0.85);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .login-container {
        background: #fffaf6;
        border-radius: 24px;
        box-shadow: 0 24px 64px rgba(80, 40, 10, 0.22);
        padding: 48px 44px 40px;
        max-width: 460px;
        width: 100%;
        border-top: 5px solid #8B5E3C;
        position: relative;
    }

    /* Decorative paw prints top-right corner */
    .login-container::before {
        content: "🐾";
        position: absolute;
        top: 16px;
        right: 20px;
        font-size: 22px;
        opacity: 0.13;
        pointer-events: none;
    }

    .login-header {
        text-align: center;
        margin-bottom: 36px;
    }

    .login-header h1 {
        color: #6b4423;
        font-size: 1.85rem;
        font-weight: 700;
        margin: 0 0 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        letter-spacing: -0.3px;
    }

    .login-header p {
        color: #a07850;
        font-size: 0.9rem;
        margin: 0;
        font-weight: 400;
    }

    .login-icon {
        width: 44px;
        height: 44px;
        background: #8B5E3C;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .error-alert {
        background: #fff3cd;
        color: #7a4f00;
        padding: 13px 16px;
        border-radius: 10px;
        margin-bottom: 24px;
        border-left: 4px solid #e6a817;
        font-size: 0.88rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Divider between fields */
    .form-divider {
        border: none;
        border-top: 1px dashed #e8d8c8;
        margin: 4px 0 20px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 7px;
        color: #6b4423;
        font-weight: 600;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }

    .form-group label i {
        font-size: 0.75rem;
        color: #a07850;
    }

    .form-control {
        width: 100%;
        padding: 13px 16px;
        border: 1.5px solid #ddd0c3;
        border-radius: 10px;
        font-size: 0.97rem;
        font-family: 'Poppins', sans-serif;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        background: #fff;
        color: #3d2b1a;
        box-sizing: border-box;
    }

    .form-control::placeholder {
        color: #c4ab96;
        font-size: 0.9rem;
    }

    .form-control:focus {
        outline: none;
        border-color: #8B5E3C;
        background: #fffcfa;
        box-shadow: 0 0 0 3px rgba(139, 94, 60, 0.12);
    }

    .btn-login {
        background: #8B5E3C;
        color: white;
        padding: 14px 24px;
        border: none;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 700;
        font-family: 'Poppins', sans-serif;
        cursor: pointer;
        transition: background 0.2s, transform 0.15s;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        margin-top: 8px;
        letter-spacing: 0.3px;
    }

    .btn-login:hover {
        background: #7a5133;
        transform: translateY(-1px);
    }

    .btn-login:active {
        transform: scale(0.99);
    }

    /* OR separator */
    .or-separator {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 18px 0;
        color: #b89880;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .or-separator::before,
    .or-separator::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e8d8c8;
    }

    .btn-google {
        background: white;
        color: #3c4043;
        padding: 12px 20px;
        border: 1.5px solid #ddd0c3;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: 'Poppins', sans-serif;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s, transform 0.15s;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
    }

    .btn-google:hover {
        background: #fdf6f0;
        border-color: #8B5E3C;
        color: #6b4423;
        transform: translateY(-1px);
    }

    .register-link {
        text-align: center;
        margin-top: 28px;
        padding-top: 22px;
        border-top: 1px solid #e8d8c8;
    }

    .register-link p {
        color: #a07850;
        font-size: 0.85rem;
        margin: 0 0 10px;
    }

    .register-link a {
        color: white;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        background: rgba(139, 94, 60, 0.75);
        padding: 9px 22px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: background 0.2s, transform 0.15s;
    }

    .register-link a:hover {
        background: rgba(139, 94, 60, 0.95);
        transform: translateY(-1px);
    }

    @media (max-width: 480px) {
        .login-container {
            padding: 32px 24px 28px;
        }

        .login-header h1 {
            font-size: 1.55rem;
        }
    }
</style>

<div class="login-overlay">
    <div class="login-container">
        {% for message in app.flashes('error') %}
            <div class="error-alert">
                <i class="fas fa-exclamation-triangle"></i>
                {{ message }}
            </div>
        {% endfor %}

        {% if error %}
            <div class="error-alert">
                <i class="fas fa-exclamation-triangle"></i>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <div class="login-header">
            <h1>
                <div class="login-icon">
                    <i class="fas fa-paw"></i>
                </div>
                Welcome Back
            </h1>
            <p>Sign in to your Pet Pantry account</p>
        </div>

        <form method="post">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label for="inputEmail">
                    <i class="fas fa-envelope"></i>
                    Email Address
                </label>
                <input
                    type="email"
                    value="{{ last_username }}"
                    name="_username"
                    id="inputEmail"
                    class="form-control"
                    autocomplete="email"
                    required
                    placeholder="you@example.com"
                >
            </div>

            <hr class="form-divider">

            <div class="form-group">
                <label for="inputPassword">
                    <i class="fas fa-lock"></i>
                    Password
                </label>
                <input
                    type="password"
                    name="_password"
                    id="inputPassword"
                    class="form-control"
                    autocomplete="current-password"
                    required
                    placeholder="Enter your password"
                >
            </div>

            <button type="submit" class="btn-login">
                <i class="fas fa-sign-in-alt"></i>
                Sign In
            </button>

            <div class="or-separator">or</div>

            <a href="{{ path('connect_google_start') }}" class="btn-google">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Sign in with Google
            </a>
        </form>

        <div class="register-link">
            <p>Don't have an account?</p>
            <a href="{{ path('app_register') }}">
                <i class="fas fa-user-plus"></i>
                Create Account
            </a>
        </div>
    </div>
</div>
{% endblock %}
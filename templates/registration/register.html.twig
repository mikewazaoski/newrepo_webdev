{% extends 'base_landing.html.twig' %}

{% block title %}Register - The Pet Pantry{% endblock %}

{% block body %}
<style>
    .register-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        background-image: url('/image/orins.png');
        background-size: cover;
        background-position: center;
        position: relative;
    }

    .register-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
    }

    .register-form-wrapper {
        position: relative;
        max-width: 500px;
        width: 100%;
        margin: 0 auto;
        padding: 40px;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18);
        backdrop-filter: blur(8px);
    }

    .register-form-wrapper h1 {
        text-align: center;
        color: #8B5E3C;
        margin: 0 0 30px 0;
        font-size: 2rem;
    }

    .register-form {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .register-form input,
    .register-form select,
    .register-form textarea {
        width: 100%;
        padding: 12px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1rem;
        transition: border-color 0.3s, box-shadow 0.3s;
        font-family: 'Poppins', sans-serif;
    }

    .register-form input:focus,
    .register-form select:focus,
    .register-form textarea:focus {
        border-color: #8B5E3C;
        outline: none;
        box-shadow: 0 0 0 3px rgba(139, 94, 60, 0.1);
    }

    .register-form label {
        display: block;
        margin-bottom: 8px;
        color: #555;
        font-weight: 500;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .checkbox-group {
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

    .checkbox-group input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
        margin-top: 5px;
        flex-shrink: 0;
    }

    .checkbox-group label {
        margin: 0;
        color: #555;
        font-size: 0.9rem;
        cursor: pointer;
    }

    .alert {
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 20px;
        border-left: 4px solid;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border-left-color: #28a745;
    }

    .alert-error {
        background: #f8d7da;
        color: #721c24;
        border-left-color: #dc3545;
    }

    .submit-btn {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #8B5E3C 0%, #A0724E 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 10px;
    }

    .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(139, 94, 60, 0.4);
    }

    .submit-btn:active {
        transform: translateY(0);
    }

    .register-footer {
        text-align: center;
        margin-top: 25px;
        color: #777;
    }

    .register-footer p {
        margin: 0 0 10px 0;
    }

    .register-footer a {
        color: #8B5E3C;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s;
    }

    .register-footer a:hover {
        color: #A0724E;
        text-decoration: underline;
    }

    /* Tablet (768px and below) */
    @media (max-width: 768px) {
        .register-container {
            padding: 20px 16px;
        }

        .register-form-wrapper {
            padding: 30px;
        }

        .register-form-wrapper h1 {
            font-size: 1.7rem;
            margin-bottom: 24px;
        }

        .register-form {
            gap: 16px;
        }

        .register-form input,
        .register-form select,
        .register-form textarea {
            padding: 11px;
            font-size: 16px;
        }

        .submit-btn {
            padding: 12px;
            font-size: 1rem;
        }
    }

    /* Mobile (480px and below) */
    @media (max-width: 480px) {
        .register-container {
            padding: 16px 12px;
            min-height: auto;
        }

        .register-form-wrapper {
            padding: 24px;
            border-radius: 12px;
        }

        .register-form-wrapper h1 {
            font-size: 1.4rem;
            margin-bottom: 20px;
        }

        .register-form {
            gap: 14px;
        }

        .register-form input,
        .register-form select,
        .register-form textarea {
            padding: 10px;
            font-size: 16px;
            border-radius: 6px;
        }

        .register-form label {
            margin-bottom: 6px;
            font-size: 0.95rem;
        }

        .checkbox-group {
            gap: 8px;
        }

        .checkbox-group label {
            font-size: 0.85rem;
        }

        .alert {
            padding: 10px;
            font-size: 0.9rem;
            margin-bottom: 16px;
        }

        .submit-btn {
            padding: 11px;
            font-size: 0.95rem;
            margin-top: 8px;
        }

        .register-footer {
            margin-top: 20px;
        }

        .register-footer p {
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .register-footer a {
            font-size: 0.9rem;
        }
    }

    /* Very small phones (320px) */
    @media (max-width: 320px) {
        .register-container {
            padding: 12px 8px;
        }

        .register-form-wrapper {
            padding: 16px;
            border-radius: 10px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        }

        .register-form-wrapper h1 {
            font-size: 1.2rem;
            margin-bottom: 16px;
        }

        .register-form {
            gap: 12px;
        }

        .register-form input,
        .register-form select,
        .register-form textarea {
            padding: 9px;
            font-size: 16px;
        }

        .register-form label {
            font-size: 0.85rem;
        }

        .submit-btn {
            padding: 10px;
            font-size: 0.9rem;
        }

        .register-footer p {
            font-size: 0.8rem;
        }

        .register-footer a {
            font-size: 0.8rem;
        }
    }
</style>

<div class="register-container">
    <div class="register-overlay"></div>
    <div class="register-form-wrapper">
        <h1>📝 Create Account</h1>
        
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-error">
                {{ message }}
            </div>
        {% endfor %}

        {% if registrationError is defined and registrationError %}
            <div class="alert alert-error">
                {{ registrationError }}
            </div>
        {% endif %}

        {{ form_start(registrationForm, {'attr': {'class': 'register-form'}}) }}
            <div class="form-group">
                {{ form_label(registrationForm.name) }}
                {{ form_widget(registrationForm.name) }}
                {{ form_errors(registrationForm.name) }}
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.email) }}
                {{ form_widget(registrationForm.email) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.username) }}
                {{ form_widget(registrationForm.username) }}
                {{ form_errors(registrationForm.username) }}
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.plainPassword.first) }}
                {{ form_widget(registrationForm.plainPassword.first) }}
                {{ form_errors(registrationForm.plainPassword.first) }}
            </div>

            <div class="form-group">
                {{ form_label(registrationForm.plainPassword.second) }}
                {{ form_widget(registrationForm.plainPassword.second) }}
                {{ form_errors(registrationForm.plainPassword.second) }}
            </div>

            <div class="checkbox-group">
                {{ form_widget(registrationForm.agreeTerms) }}
                {{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'style': ''}}) }}
            </div>
            {{ form_errors(registrationForm.agreeTerms) }}

            <button type="submit" class="submit-btn">Register</button>
        {{ form_end(registrationForm) }}

        <div class="register-footer">
            <p>Already have an account?</p>
            <a href="{{ path('app_login') }}">Sign In →</a>
        </div>
    </div>
</div>
{% endblock %}


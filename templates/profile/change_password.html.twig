{% extends 'base.html.twig' %}

{% block title %}Change Password{% endblock %}

{% block body %}
<div>
    <h1 style="color: #8B5E3C; margin-bottom: 30px; font-size: 2.2rem;">🔑 Change Password</h1>

    {% for message in app.flashes('success') %}
        <div style="background: #d4edda; color: #155724; padding: 12px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #28a745;">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #dc3545;">
            {{ message }}
        </div>
    {% endfor %}

    {{ form_start(form, {'attr': {'class': 'card', 'style': 'max-width: 600px;'}}) }}
        {{ form_row(form.currentPassword, {'attr': {'style': 'width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1rem;'}}) }}
        {{ form_row(form.newPassword.first, {'attr': {'style': 'width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1rem;'}}) }}
        {{ form_row(form.newPassword.second, {'attr': {'style': 'width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1rem;'}}) }}

        <div style="display: flex; gap: 10px; margin-top: 20px;">
            <button type="submit" class="btn-primary">Change Password</button>
            <a href="{{ path('app_profile_show') }}" style="padding: 12px 28px; background: #6c757d; color: white; text-decoration: none; border-radius: 10px; display: inline-block;">Cancel</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}


{% extends 'base_landing.html.twig' %}

{% block title %}Our History - The Pet Pantry{% endblock %}

{% block body %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink:        #1a130b;
    --ink-soft:   #4a3a2d;
    --gold:       #b87333;
    --gold-light: #d4955a;
    --gold-pale:  #f0d9bc;
    --parchment:  #faf5ed;
    --parchment-2:#f3ebe0;
    --white:      #ffffff;
    --rule:       rgba(184,115,51,0.20);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--parchment);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.6;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    grid-template-columns: 55% 45%;
    overflow: hidden;
  }

  .hero-image-wrap {
    position: relative;
    overflow: hidden;
  }

  .hero-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.85) brightness(0.96);
    transform-origin: center;
    animation: heroZoom 12s ease-in-out infinite alternate;
  }

  @keyframes heroZoom {
    from { transform: scale(1); }
    to   { transform: scale(1.06); }
  }

  .hero-image-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right,  transparent 55%, var(--parchment) 100%),
      linear-gradient(to bottom, rgba(26,19,11,0.18) 0%, transparent 40%);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 72px 80px 56px;
    position: relative;
    z-index: 2;
    background: var(--parchment);
  }

  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.70rem;
    font-weight: 500;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    opacity: 0;
    animation: riseIn 0.8s cubic-bezier(0.16,1,0.3,1) 0.3s forwards;
  }

  .hero-label::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--gold);
  }

  .hero-headline {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(3.2rem, 6vw, 5.8rem);
    font-weight: 400;
    line-height: 0.95;
    color: var(--ink);
    letter-spacing: -1px;
    margin-bottom: 32px;
    opacity: 0;
    animation: riseIn 0.9s cubic-bezier(0.16,1,0.3,1) 0.5s forwards;
  }

  .hero-headline em {
    font-style: italic;
    color: var(--gold);
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    background: var(--gold);
    margin-bottom: 28px;
    opacity: 0;
    animation: riseIn 0.8s cubic-bezier(0.16,1,0.3,1) 0.65s forwards;
  }

  .hero-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.85;
    color: var(--ink-soft);
    max-width: 380px;
    opacity: 0;
    animation: riseIn 0.8s cubic-bezier(0.16,1,0.3,1) 0.75s forwards;
  }

  .hero-watermark {
    position: absolute;
    bottom: 40px;
    right: 56px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 11rem;
    font-weight: 300;
    color: var(--gold-pale);
    line-height: 1;
    user-select: none;
    pointer-events: none;
    opacity: 0;
    animation: riseIn 1s cubic-bezier(0.16,1,0.3,1) 1s forwards;
  }

  @keyframes riseIn {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── STATS STRIP ── */
  .intro-strip {
    background: var(--ink);
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    overflow: hidden;
  }

  .intro-stat {
    padding: 52px 48px;
    border-right: 1px solid rgba(255,255,255,0.07);
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: relative;
    overflow: hidden;
  }

  .intro-stat:last-child { border-right: none; }

  .intro-stat::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s cubic-bezier(0.22,1,0.36,1);
  }

  .intro-stat.revealed::before { transform: scaleX(1); }

  .intro-stat-num {
    font-family: 'DM Serif Display', serif;
    font-size: 3.2rem;
    color: var(--gold-light);
    line-height: 1;
  }

  .intro-stat-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.80rem;
    font-weight: 300;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.50);
  }

  /* ── SECTION HEADER ── */
  .section-header {
    padding: 100px 80px 60px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }

  .section-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--gold);
  }

  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.2rem, 4vw, 3.6rem);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.1;
    max-width: 500px;
  }

  .section-title em { font-style: italic; color: var(--gold); }

  .section-desc {
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 1.9;
    color: var(--ink-soft);
    max-width: 360px;
    flex-shrink: 0;
    padding-bottom: 6px;
  }

  /* ── TIMELINE ── */
  .timeline {
    padding: 0 80px 120px;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: calc(80px + 28px);
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent 0%, var(--rule) 10%, var(--rule) 90%, transparent 100%);
  }

  .tl-entry {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 0 64px;
    padding: 0 0 80px 0;
    position: relative;
  }

  .tl-entry:last-child { padding-bottom: 0; }

  .tl-marker-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 6px;
  }

  .tl-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--gold);
    background: var(--parchment);
    box-shadow: 0 0 0 4px var(--gold-pale);
    flex-shrink: 0;
    transition: background 0.3s, box-shadow 0.3s;
    position: relative;
    z-index: 2;
  }

  .tl-entry:hover .tl-dot {
    background: var(--gold);
    box-shadow: 0 0 0 6px rgba(184,115,51,0.15);
  }

  .tl-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .tl-entry.flip .tl-body {
    direction: rtl;
  }
  .tl-entry.flip .tl-text,
  .tl-entry.flip .tl-image-wrap {
    direction: ltr;
  }

  .tl-year-wrap {
    position: relative;
    padding-top: 60px;
    margin-bottom: 6px;
  }

  .tl-year-num {
    font-family: 'DM Serif Display', serif;
    font-size: 6rem;
    font-weight: 400;
    color: var(--gold-pale);
    line-height: 1;
    letter-spacing: -3px;
    user-select: none;
    pointer-events: none;
  }

  .tl-year-label {
    position: absolute;
    bottom: 8px;
    left: 2px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
  }

  .tl-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.7rem;
    font-weight: 400;
    line-height: 1.2;
    color: var(--ink);
    margin-bottom: 20px;
    letter-spacing: -0.3px;
  }

  .tl-desc {
    font-size: 0.90rem;
    font-weight: 300;
    line-height: 1.95;
    color: var(--ink-soft);
  }

  .tl-rule {
    width: 36px;
    height: 1px;
    background: var(--gold);
    margin: 24px 0;
    transition: width 0.5s cubic-bezier(0.22,1,0.36,1);
  }

  .tl-entry:hover .tl-rule { width: 60px; }

  .tl-image-wrap {
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    height: 360px;
    background: var(--parchment-2);
  }

  .tl-image-wrap::before {
    content: '';
    position: absolute;
    inset: -1px;
    border: 1px solid var(--rule);
    border-radius: 4px;
    z-index: 2;
    pointer-events: none;
  }

  .tl-image-wrap::after {
    content: '';
    position: absolute;
    bottom: -8px;
    right: -8px;
    width: 48px;
    height: 48px;
    border-bottom: 2px solid var(--gold);
    border-right: 2px solid var(--gold);
    z-index: 3;
    pointer-events: none;
    transition: width 0.4s, height 0.4s;
  }

  .tl-entry:hover .tl-image-wrap::after {
    width: 64px;
    height: 64px;
  }

  .tl-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.90);
    transition: transform 0.8s cubic-bezier(0.22,1,0.36,1), filter 0.5s;
  }

  .tl-entry:hover .tl-image-wrap img {
    transform: scale(1.06);
    filter: saturate(1.05);
  }

  /* ── CLOSING ── */
  .closing {
    background: var(--ink);
    padding: 120px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .closing::before {
    content: '';
    position: absolute;
    top: -120px; right: -80px;
    width: 480px; height: 480px;
    border-radius: 50%;
    border: 1px solid rgba(184,115,51,0.12);
  }

  .closing::after {
    content: '';
    position: absolute;
    bottom: -160px; left: -60px;
    width: 380px; height: 380px;
    border-radius: 50%;
    border: 1px solid rgba(184,115,51,0.08);
  }

  .closing-text { position: relative; z-index: 1; }

  .closing-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .closing-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--gold-light);
  }

  .closing-headline {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--white);
    margin-bottom: 32px;
    letter-spacing: -0.5px;
  }

  .closing-headline em {
    font-style: italic;
    color: var(--gold-light);
  }

  .closing-body {
    font-size: 0.92rem;
    font-weight: 300;
    line-height: 2;
    color: rgba(255,255,255,0.55);
    max-width: 440px;
  }

  .closing-paw {
    font-size: 5rem;
    line-height: 1;
    justify-self: center;
    align-self: center;
    position: relative;
    z-index: 1;
    animation: floatPaw 4s ease-in-out infinite;
    filter: drop-shadow(0 12px 32px rgba(184,115,51,0.3));
  }

  @keyframes floatPaw {
    0%, 100% { transform: translateY(0) rotate(-3deg); }
    50%       { transform: translateY(-14px) rotate(3deg); }
  }

  .closing-rule {
    width: 48px;
    height: 1px;
    background: rgba(184,115,51,0.4);
    margin: 32px 0;
  }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1),
                transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }

  .reveal-l {
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1),
                transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }

  .reveal-r {
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1),
                transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }

  .reveal.revealed,
  .reveal-l.revealed,
  .reveal-r.revealed {
    opacity: 1;
    transform: translate(0);
  }

  .reveal[data-delay="1"]   { transition-delay: 0.1s; }
  .reveal[data-delay="2"]   { transition-delay: 0.2s; }
  .reveal[data-delay="3"]   { transition-delay: 0.3s; }
  .reveal-l[data-delay="1"] { transition-delay: 0.15s; }
  .reveal-r[data-delay="1"] { transition-delay: 0.25s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-image-wrap { min-height: 50svh; }
    .hero-image-wrap::after { display: none; }
    .hero-text { padding: 56px 40px; }
    .hero-watermark { display: none; }

    .intro-strip { grid-template-columns: 1fr; }
    .intro-stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.07); }
    .intro-stat:last-child { border-bottom: none; }

    .section-header { flex-direction: column; padding: 64px 40px 40px; }
    .timeline { padding: 0 40px 80px; }
    .timeline::before { left: calc(40px + 28px); }

    .tl-body { grid-template-columns: 1fr; gap: 32px; }
    .tl-entry.flip .tl-body { direction: ltr; }
    .tl-image-wrap { height: 260px; }

    .closing { grid-template-columns: 1fr; padding: 80px 40px; gap: 40px; }
    .closing-paw { display: none; }
  }

  @media (max-width: 600px) {
    .hero-headline { font-size: 2.6rem; }
    .timeline { padding: 0 24px 60px; }
    .timeline::before { display: none; }
    .tl-entry { grid-template-columns: 1fr; }
    .tl-marker-col { display: none; }
    .tl-year-num { font-size: 4rem; }
    .section-header { padding: 48px 24px 32px; }
    .closing { padding: 64px 24px; }
  }
</style>

<!-- HERO -->
<section class="hero">
  <div class="hero-image-wrap">
    <img src="{{ asset('image/cathis.png') }}" alt="The Pet Pantry — Our Heritage">
  </div>
  <div class="hero-text">
    <div class="hero-label">The Pet Pantry</div>
    <h1 class="hero-headline">Our<br><em>History</em></h1>
    <div class="hero-rule"></div>
    <p class="hero-desc">The journey of The Pet Pantry began with a simple dream: to create a haven where pet lovers could find everything they need for their beloved companions.</p>
    <div class="hero-watermark" aria-hidden="true">III</div>
  </div>
</section>

<!-- STATS STRIP -->
<div class="intro-strip">
  <div class="intro-stat reveal">
    <div class="intro-stat-num">2022</div>
    <div class="intro-stat-label">Year Founded</div>
  </div>
  <div class="intro-stat reveal" data-delay="1">
    <div class="intro-stat-num">3+</div>
    <div class="intro-stat-label">Years of Service</div>
  </div>
  <div class="intro-stat reveal" data-delay="2">
    <div class="intro-stat-num">∞</div>
    <div class="intro-stat-label">Passion for Pets</div>
  </div>
</div>

<!-- SECTION HEADER -->
<div class="section-header">
  <div class="reveal">
    <div class="section-eyebrow">Our Story</div>
    <h2 class="section-title">A <em>timeline</em> of care &amp; commitment</h2>
  </div>
  <p class="section-desc reveal" data-delay="1">
    From a modest beginning in Dumaguete City to becoming a trusted name in pet nutrition — every chapter has been written with love for animals.
  </p>
</div>

<!-- TIMELINE -->
<div class="timeline">

  <!-- 2022 -->
  <div class="tl-entry reveal">
    <div class="tl-marker-col">
      <div class="tl-dot"></div>
    </div>
    <div class="tl-body">
      <div class="tl-text reveal-l">
        <div class="tl-year-wrap">
          <div class="tl-year-num" aria-hidden="true">2022</div>
          <div class="tl-year-label">Chapter One</div>
        </div>
        <h3 class="tl-title">Pets Pantry is Founded in Brgy. Piapi, Dumaguete City</h3>
        <div class="tl-rule"></div>
        <p class="tl-desc">The Pets Pantry was founded by Mike Marco who began with pet feeding at their local adoption centre in Canlaon City — driven by a greater ambition to create high-quality, convenient nutrition for companion animals.</p>
      </div>
      <div class="tl-image-wrap reveal-r">
        <img src="{{ asset('image/founder.png') }}" alt="2022 — Pets Pantry Founded">
      </div>
    </div>
  </div>

  <!-- 2023 -->
  <div class="tl-entry flip reveal">
    <div class="tl-marker-col">
      <div class="tl-dot"></div>
    </div>
    <div class="tl-body">
      <div class="tl-text reveal-r">
        <div class="tl-year-wrap">
          <div class="tl-year-num" aria-hidden="true">2023</div>
          <div class="tl-year-label">Chapter Two</div>
        </div>
        <h3 class="tl-title">First Dedicated Nutrition Centre for Dogs</h3>
        <div class="tl-rule"></div>
        <p class="tl-desc">Pets Pantry opens the industry's first dedicated pet nutrition centre in Brgy. Daro, Dumaguete City. Backed by feeding studies and data-driven testing, this set a new standard in understanding the nutritional needs of dogs.</p>
      </div>
      <div class="tl-image-wrap reveal-l">
        <img src="{{ asset('image/doggos.png') }}" alt="2023 — First treat nutrition for dogs">
      </div>
    </div>
  </div>

  <!-- 2024 -->
  <div class="tl-entry reveal">
    <div class="tl-marker-col">
      <div class="tl-dot"></div>
    </div>
    <div class="tl-body">
      <div class="tl-text reveal-l">
        <div class="tl-year-wrap">
          <div class="tl-year-num" aria-hidden="true">2024</div>
          <div class="tl-year-label">Chapter Three</div>
        </div>
        <h3 class="tl-title">Pioneering Dry Cat Food Enriched with Taurine</h3>
        <div class="tl-rule"></div>
        <p class="tl-desc">Pets Pantry becomes among the first to enrich dry cat food with taurine — an essential amino acid for feline health. This breakthrough helps prevent serious conditions like vision loss and heart disease, cementing our role as a leader in feline nutrition.</p>
      </div>
      <div class="tl-image-wrap reveal-r">
        <img src="{{ asset('image/dryfood.png') }}" alt="2024 — Dry cat food with taurine">
      </div>
    </div>
  </div>

  <!-- 2025 -->
  <div class="tl-entry flip reveal">
    <div class="tl-marker-col">
      <div class="tl-dot"></div>
    </div>
    <div class="tl-body">
      <div class="tl-text reveal-r">
        <div class="tl-year-wrap">
          <div class="tl-year-num" aria-hidden="true">2025</div>
          <div class="tl-year-label">Chapter Four</div>
        </div>
        <h3 class="tl-title">Championing Science-Based Pet Nutrition Citywide</h3>
        <div class="tl-rule"></div>
        <p class="tl-desc">Rooted in years of science, Pets Pantry expands its mission to champion nutritional knowledge across Dumaguete City. With a mission to help pets live longer, healthier lives, we empower veterinarians to elevate science-based nutrition in everyday care.</p>
      </div>
      <div class="tl-image-wrap reveal-l">
        <img src="{{ asset('image/cd.png') }}" alt="2025 — Pets Pantry expands">
      </div>
    </div>
  </div>

</div>

<!-- CLOSING -->
<section class="closing">
  <div class="closing-text reveal-l">
    <div class="closing-eyebrow">Still Writing</div>
    <h2 class="closing-headline">A legacy built on <em>love &amp; science</em></h2>
    <div class="closing-rule"></div>
    <p class="closing-body">Today, The Pet Pantry stands as a testament to our unwavering commitment to pet welfare. We continue to evolve — always keeping the needs of pets and their owners at the heart of everything we do.</p>
  </div>
  <div class="closing-paw reveal-r" aria-hidden="true">🐾</div>
</section>

<script>
(function () {
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('revealed');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.10, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll(
    '.reveal, .reveal-l, .reveal-r, .intro-stat, .tl-divider'
  ).forEach(function (el) { io.observe(el); });
})();
</script>


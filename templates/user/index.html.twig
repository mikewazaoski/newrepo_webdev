{% extends 'base.html.twig' %}

{% block title %}User Management{% endblock %}

{% block body %}
<div>
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="color: #8B5E3C; margin: 0; font-size: 2.2rem;">👥 User Management</h1>
        <a href="{{ path('app_user_new') }}" style="padding: 12px 28px; background: linear-gradient(135deg, #8B5E3C 0%, #A0724E 100%); color: white; text-decoration: none; border-radius: 10px; font-weight: 600; display: inline-block; box-shadow: 0 4px 15px rgba(139, 94, 60, 0.3); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(139, 94, 60, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(139, 94, 60, 0.3)'">
            <i class="fas fa-plus"></i> Create New User
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="success-message" style="background: #d4edda; color: #155724; padding: 12px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #28a745; transition: opacity 0.5s ease-out;">
            {{ message }}
        </div>
    {% endfor %}

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const successMessages = document.querySelectorAll('.success-message');
            successMessages.forEach(function(message) {
                setTimeout(function() {
                    message.style.opacity = '0';
                    setTimeout(function() {
                        message.remove();
                    }, 500);
                }, 5000);
            });
        });
    </script>

    <div class="card">
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8f9fa; border-bottom: 2px solid #e0e0e0;">
                        <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Username</th>
                        <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Email</th>
                        <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Name</th>
                        <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Role</th>
                        <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Status</th>
                        <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Date Created</th>
                        <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr style="border-bottom: 1px solid #e0e0e0;">
                            <td style="padding: 12px;">{{ user.username }}</td>
                            <td style="padding: 12px;">{{ user.email }}</td>
                            <td style="padding: 12px;">{{ user.name }}</td>
                            <td style="padding: 12px;">
                                <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.85rem; font-weight: 600;
                                    {% if 'ROLE_ADMIN' in user.roles %}background: #f8d7da; color: #721c24;
                                    {% else %}background: #d1ecf1; color: #0c5460;{% endif %}">
                                    {% if 'ROLE_ADMIN' in user.roles %}Admin{% else %}Staff{% endif %}
                                </span>
                            </td>
                            <td style="padding: 12px;">
                                <span style="padding: 4px 8px; border-radius: 4px; font-size: 0.85rem; font-weight: 600;
                                    {% if user.isActive %}background: #d4edda; color: #155724;
                                    {% else %}background: #f8d7da; color: #721c24;{% endif %}">
                                    {% if user.isActive %}Active{% else %}Inactive{% endif %}
                                </span>
                            </td>
                            <td style="padding: 12px; color: #666;">{{ user.createdAt|date('Y-m-d') }}</td>
                            <td style="padding: 12px;">
                                <div style="display: flex; gap: 8px;">
                                    <a href="{{ path('app_user_show', {'id': user.id}) }}" style="color: #8B5E3C; text-decoration: none;" title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_user_edit', {'id': user.id}) }}" style="color: #8B5E3C; text-decoration: none;" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_user_toggle_status', {'id': user.id}) }}" style="display: inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                        <button type="submit" style="background: none; border: none; color: #8B5E3C; cursor: pointer;" title="Toggle Status">
                                            <i class="fas fa-toggle-{% if user.isActive %}on{% else %}off{% endif %}"></i>
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                        <button type="submit" style="background: none; border: none; color: #dc3545; cursor: pointer;" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" style="padding: 40px; text-align: center; color: #999;">No users found</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}


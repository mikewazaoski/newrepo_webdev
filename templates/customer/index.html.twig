{% extends 'base.html.twig' %}

{% block title %}Customers - Pets Pantry{% endblock %}

{% block body %}
<div style="padding: 30px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="color: #8B5E3C; margin: 0; font-size: 2.2rem;">👥 Customers</h1>
        <a href="{{ path('app_customer_new') }}" style="padding: 12px 28px; background: linear-gradient(135deg, #8B5E3C 0%, #A0724E 100%); color: white; text-decoration: none; border-radius: 10px; font-weight: 600; display: inline-block; box-shadow: 0 4px 15px rgba(139, 94, 60, 0.3); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(139, 94, 60, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(139, 94, 60, 0.3)'">
            <i class="fas fa-plus"></i> Create New Customer
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div style="background: #d4edda; color: #155724; padding: 12px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #28a745;">
            {{ message }}
        </div>
    {% endfor %}

    {% if customers|length > 0 %}
    <div class="card" style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8f9fa; border-bottom: 2px solid #e0e0e0;">
                    <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Name</th>
                    <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Email</th>
                    <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Customer Name</th>
                    <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Username</th>
                    <th style="padding: 12px; text-align: left; color: #666; font-weight: 600;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for customer in customers %}
                    <tr style="border-bottom: 1px solid #e0e0e0;">
                        <td style="padding: 12px;">{{ customer.name }}</td>
                        <td style="padding: 12px;">{{ customer.email }}</td>
                        <td style="padding: 12px;">{{ customer.customerName|default('N/A') }}</td>
                        <td style="padding: 12px;">{{ customer.username|default('N/A') }}</td>
                        <td style="padding: 12px;">
                            <div style="display: flex; gap: 10px;">
                                <a href="{{ path('app_customer_show', {'id': customer.id}) }}" style="color: #8B5E3C; text-decoration: none; font-size: 1.2rem;" title="View">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('app_customer_edit', {'id': customer.id}) }}" style="color: #8B5E3C; text-decoration: none; font-size: 1.2rem;" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="{{ path('app_customer_delete', {'id': customer.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this customer? This action cannot be undone.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ customer.id) }}">
                                    <button type="submit" style="background: none; border: none; color: #dc3545; cursor: pointer; font-size: 1.2rem;" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="card" style="text-align: center; padding: 60px 20px;">
        <i class="fas fa-users" style="font-size: 4rem; color: #ccc; margin-bottom: 20px;"></i>
        <h3 style="color: #666; margin-bottom: 10px;">No Customers Yet</h3>
        <p style="color: #999; margin-bottom: 30px;">Start by creating your first customer</p>
        <a href="{{ path('app_customer_new') }}" style="padding: 12px 28px; background: linear-gradient(135deg, #8B5E3C 0%, #A0724E 100%); color: white; text-decoration: none; border-radius: 10px; font-weight: 600; display: inline-block;">
            <i class="fas fa-plus"></i> Create First Customer
        </a>
    </div>
    {% endif %}
</div>
{% endblock %}


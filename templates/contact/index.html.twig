{% extends 'base_landing.html.twig' %}

{% block title %}Contact Us - The Pet Pantry{% endblock %}

{% block body %}
<style>
    /* Import a modern, friendly font */
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

    :root {
        --brand-primary: #8B5E3C;
        --brand-secondary: #A0724E;
        --brand-accent: #f4eadd;
        --text-dark: #2c1e16;
        --text-light: #786d66;
        --bg-color: #fdfbf9;
        --card-bg: #ffffff;
        --shadow-sm: 0 4px 6px rgba(139, 94, 60, 0.05);
        --shadow-md: 0 12px 30px rgba(139, 94, 60, 0.08);
        --shadow-hover: 0 20px 40px rgba(139, 94, 60, 0.12);
        --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    * {
        box-sizing: border-box;
    }

    .contact-container {
        max-width: 1100px;
        margin: 80px auto;
        padding: 0 24px;
        font-family: 'Outfit', sans-serif;
    }
    
    /* --- ANIMATIONS --- */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes pulseSoftly {
        0% { box-shadow: 0 0 0 0 rgba(139, 94, 60, 0.4); }
        70% { box-shadow: 0 0 0 15px rgba(139, 94, 60, 0); }
        100% { box-shadow: 0 0 0 0 rgba(139, 94, 60, 0); }
    }
    
    /* --- HEADER --- */
    .contact-header {
        text-align: center;
        margin-bottom: 60px;
        animation: fadeInUp 0.8s ease-out forwards;
    }
    
    .contact-header h1 {
        color: var(--text-dark);
        font-size: 3.5rem;
        font-weight: 700;
        margin-bottom: 16px;
        letter-spacing: -0.02em;
    }

    .contact-header h1::after {
        content: '';
        display: block;
        width: 80px;
        height: 4px;
        background: linear-gradient(90deg, var(--brand-primary), var(--brand-secondary));
        margin: 20px auto 0;
        border-radius: 4px;
    }
    
    .contact-header p {
        color: var(--text-light);
        font-size: 1.25rem;
        line-height: 1.7;
        max-width: 600px;
        margin: 0 auto;
        font-weight: 300;
    }
    
    /* --- LAYOUT --- */
    .contact-content {
        display: grid;
        grid-template-columns: 1fr 1.2fr; /* Give the form slightly more room */
        gap: 40px;
        margin-bottom: 40px;
    }
    
    /* --- CONTACT INFO CARD --- */
    .contact-info {
        background: var(--card-bg);
        border-radius: 24px;
        box-shadow: var(--shadow-md);
        padding: 48px;
        border: 1px solid rgba(139, 94, 60, 0.1);
        transition: var(--transition-smooth);
        animation: fadeInUp 0.8s ease-out 0.2s forwards;
        opacity: 0; /* for animation */
        height: fit-content;
    }

    .contact-info:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-hover);
    }
    
    .info-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 32px;
        padding-bottom: 24px;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    
    .info-icon {
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-secondary) 100%);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.8rem;
        box-shadow: 0 8px 16px rgba(139, 94, 60, 0.25);
        animation: pulseSoftly 3s infinite;
    }
    
    .info-title {
        color: var(--text-dark);
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0;
    }
    
    .info-details {
        color: var(--text-light);
        line-height: 1.6;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    
    .info-details p {
        margin: 0;
        display: flex;
        align-items: flex-start;
        gap: 16px;
        font-size: 1.05rem;
        transition: var(--transition-smooth);
    }

    .info-details p:hover {
        color: var(--brand-primary);
        transform: translateX(5px);
    }
    
    .info-details i {
        color: var(--brand-primary);
        font-size: 1.2rem;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--brand-accent);
        padding: 20px;
        border-radius: 12px;
        transition: var(--transition-smooth);
    }

    .info-details p:hover i {
        background: var(--brand-primary);
        color: white;
    }
    
    /* --- CONTACT FORM (IFRAME & NATIVE) --- */
    .contact-form {
        background: var(--card-bg);
        border-radius: 24px;
        box-shadow: var(--shadow-md);
        padding: 40px;
        border: 1px solid rgba(139, 94, 60, 0.1);
        animation: fadeInUp 0.8s ease-out 0.4s forwards;
        opacity: 0; /* for animation */
        transition: var(--transition-smooth);
        overflow: hidden;
    }

    .contact-form:hover {
        box-shadow: var(--shadow-hover);
    }

    /* Iframe specific tweak */
    .contact-form iframe {
        border-radius: 12px;
        background: transparent;
    }
    
    /* Maintained Native Form Styling (in case of switch from Google Forms) */
    .form-group {
        margin-bottom: 24px;
    }
    
    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: var(--text-dark);
        font-weight: 600;
        font-size: 0.95rem;
    }
    
    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #f0f0f0;
        border-radius: 16px;
        font-size: 1rem;
        font-family: inherit;
        transition: var(--transition-smooth);
        background: #fafafa;
        color: var(--text-dark);
    }
    
    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--brand-secondary);
        background: white;
        box-shadow: 0 0 0 4px rgba(139, 94, 60, 0.1);
    }
    
    .form-group textarea {
        min-height: 150px;
        resize: vertical;
    }
    
    .btn-submit {
        background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-secondary) 100%);
        color: white;
        padding: 18px 32px;
        border: none;
        border-radius: 16px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition-smooth);
        box-shadow: 0 8px 20px rgba(139, 94, 60, 0.25);
        width: 100%;
        letter-spacing: 0.5px;
    }
    
    .btn-submit:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 25px rgba(139, 94, 60, 0.35);
    }
    
    /* --- FLASH MESSAGES --- */
    .flash-messages {
        margin-bottom: 30px;
        animation: fadeInUp 0.5s ease-out;
    }
    
    .flash-message {
        padding: 18px 24px;
        border-radius: 16px;
        margin-bottom: 16px;
        border-left: 6px solid;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: var(--shadow-sm);
    }
    
    .flash-success {
        background: #f0fdf4;
        color: #166534;
        border-left-color: #22c55e;
    }
    
    .flash-error {
        background: #fef2f2;
        color: #991b1b;
        border-left-color: #ef4444;
    }
    
    /* --- RESPONSIVE DESIGN --- */
    @media (max-width: 900px) {
        .contact-content {
            grid-template-columns: 1fr;
            gap: 32px;
        }
    }

    @media (max-width: 768px) {
        .contact-container {
            margin: 40px auto;
            padding: 0 20px;
        }
        
        .contact-header h1 {
            font-size: 2.5rem;
        }
        
        .contact-info, .contact-form {
            padding: 32px 24px;
        }

        .info-header {
            flex-direction: column;
            text-align: center;
            gap: 16px;
        }
        
        .info-details p {
            align-items: center;
            flex-direction: column;
            text-align: center;
            gap: 12px;
        }

        .info-details i {
            margin: 0 auto;
        }
    }
</style>

<div class="contact-container">
    <header class="contact-header">
        <h1>Get in Touch</h1>
        <p>We're here to help! Reach out to us for any questions, suggestions, or support. Your furry friends are our priority.</p>
    </header>

    {% for message in app.flashes('success') %}
        <div class="flash-messages">
            <div class="flash-message flash-success">
                {{ message }}
            </div>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash-messages">
            <div class="flash-message flash-error">
                {{ message }}
            </div>
        </div>
    {% endfor %}

    <div class="contact-content">
        <div class="contact-info">
            <div class="info-header">
                <div class="info-icon">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <h2 class="info-title">Visit Our Store</h2>
            </div>
            <div class="info-details">
                <p>
                    <i class="fas fa-clock"></i>
                    <span>Monday - Friday: 9:00 AM - 6:00 PM</span>
                </p>
                <p>
                    <i class="fas fa-phone"></i>
                    <span>+63 926 702 7071</span>
                </p>
                <p>
                    <i class="fas fa-envelope"></i>
                    <span>petspantry@gmail.com</span>
                </p>
                <p>
                    <i class="fas fa-globe"></i>
                    <span>Tubod, Piapi, Dumaguete City, Negros Oriental</span>
                </p>
            </div>
        </div>

        <div class="contact-form">
            <iframe src="https://docs.google.com/forms/d/e/1FAIpQLSdFXqFESt-4VRdUrG7QR0uYYZHGTWbkGYyKX6azsvatQAPZgA/viewform?embedded=true" width="100%" height="600" frameborder="0" marginheight="0" marginwidth="0">Loading…</iframe>
        </div>
    </div>
</div>
{% endblock %}
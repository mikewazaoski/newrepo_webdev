{% extends 'base.html.twig' %}

{% block title %}Product Inventory - Pets Pantry{% endblock %}

{% block body %}
<div class="inventory-header">
    <h1>Product Inventory 🐾</h1>
    <a href="{{ path('app_product_new') }}" class="create-btn">+ Create New Product</a>
</div>

{% if is_granted('ROLE_USER') %}
<div style="background: white; padding: 20px; border-radius: 12px; margin-bottom: 30px; border: 1px solid #e5e5e5;">
    <h2 style="color: #8B5E3C; margin-bottom: 15px; font-size: 1.2rem;">🔍 Search & Filter</h2>
    <form method="get" style="display: grid; grid-template-columns: 2fr 1fr auto; gap: 15px; align-items: end;">
        <div>
            <label for="search" style="display: block; margin-bottom: 5px; color: #666; font-weight: 500;">Search:</label>
            <input type="text" name="search" id="search" value="{{ search }}" placeholder="Search by name or description..." style="width: 100%; padding: 10px; border: 2px solid #e0e0e0; border-radius: 8px;">
        </div>
        <div>
            <label for="category" style="display: block; margin-bottom: 5px; color: #666; font-weight: 500;">Category:</label>
            <select name="category" id="category" style="width: 100%; padding: 10px; border: 2px solid #e0e0e0; border-radius: 8px;">
                <option value="">All Categories</option>
                {% for category in categories %}
                    <option value="{{ category.id }}" {% if category_id == category.id %}selected{% endif %}>
                        {{ category.name }}
                    </option>
                {% endfor %}
            </select>
        </div>
        <div style="display: flex; gap: 10px;">
            <button type="submit" style="padding: 10px 20px; background: #8B5E3C; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600;">Filter</button>
            <a href="{{ path('app_product_index') }}" style="padding: 10px 20px; background: #6c757d; color: white; text-decoration: none; border-radius: 8px; display: inline-block; font-weight: 600;">Clear</a>
        </div>
    </form>
</div>
{% endif %}

<div class="products-grid">
    {% for product in products %}
        <div class="product-card">
            <div class="product-image-wrapper">
                {% if product.image %}
                    <img src="{{ asset('uploads/images/' ~ product.image) }}" alt="{{ product.name }}" class="product-image">
                {% else %}
                    <div class="no-image-placeholder">
                        <i class="fas fa-paw"></i>
                        <span>No Image</span>
                    </div>
                {% endif %}
                <button class="favorite-btn">
                    <i class="far fa-heart"></i>
                </button>
            </div>
            
            <div class="product-info">
                <h3 class="product-name">{{ product.name }}</h3>
                
                <div class="product-price">₱{{ product.price }}</div>

                <div style="font-weight: 800; color: #2E7D32; margin-top: 6px;">
                    Stock: {{ product.stock }}
                </div>
                
                <div class="product-category">
                    {% if product.category %}
                        {{ product.category.name }}
                    {% else %}
                        <em>No Category</em>
                    {% endif %}
                </div>

                {% if product.description %}
                    <p class="product-description">{{ product.description|length > 60 ? product.description|slice(0, 60) ~ '...' : product.description }}</p>
                {% endif %}

                <div class="product-actions">
                    <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn show">Show</a>
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn edit">Edit</a>
                    {% endif %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="no-products">
            <i class="fas fa-box-open"></i>
            <p>No products found</p>
            <a href="{{ path('app_product_new') }}" class="create-btn">+ Create Your First Product</a>
        </div>
    {% endfor %}
</div>

{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .inventory-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px solid rgba(62, 39, 35, 0.1);
    }

    .inventory-header h1 {
        margin: 0;
        color: #3E2723;
        font-size: 2rem;
        font-weight: 600;
    }

    /* Products Grid */
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 25px;
        padding: 10px 0;
    }

    /* Product Card */
    .product-card {
        background: #FFFFFF;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        border: 1px solid rgba(62, 39, 35, 0.1);
        display: flex;
        flex-direction: column;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 24px rgba(62, 39, 35, 0.15);
    }

    /* Product Image */
    .product-image-wrapper {
        position: relative;
        width: 100%;
        padding-top: 100%; /* 1:1 Aspect Ratio */
        background: #F5F5F5;
        overflow: hidden;
    }

    .product-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .product-card:hover .product-image {
        transform: scale(1.05);
    }

    .no-image-placeholder {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #F5F5F5 0%, #E0E0E0 100%);
        color: #8D6E63;
    }

    .no-image-placeholder i {
        font-size: 3rem;
        margin-bottom: 10px;
        opacity: 0.5;
    }

    .no-image-placeholder span {
        font-size: 0.9rem;
        font-weight: 500;
    }

    /* Favorite Button */
    .favorite-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #FFFFFF;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        z-index: 10;
    }

    .favorite-btn i {
        font-size: 1.1rem;
        color: #3E2723;
        transition: all 0.3s ease;
    }

    .favorite-btn:hover {
        transform: scale(1.1);
        background: #3E2723;
    }

    .favorite-btn:hover i {
        color: #FFF8E1;
    }

    .favorite-btn.active i {
        color: #FFE0B2;
    }

    /* Product Info */
    .product-info {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }

    .product-name {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: #3E2723;
        line-height: 1.3;
        min-height: 2.6em;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-price {
        font-size: 1.3rem;
        font-weight: 700;
        color: #4E342E;
        margin: 5px 0;
    }

    .product-category {
        display: inline-block;
        padding: 4px 12px;
        background: #FFF8E1;
        color: #3E2723;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 500;
        width: fit-content;
    }

    .product-category em {
        color: #8D6E63;
        font-style: normal;
    }

    .product-description {
        font-size: 0.9rem;
        color: #4E342E;
        line-height: 1.5;
        margin: 5px 0 0 0;
        flex: 1;
    }

    /* Product Actions */
    .product-actions {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        padding-top: 15px;
        border-top: 1px solid #F0F0F0;
    }

    .btn {
        flex: 1;
        padding: 10px 16px;
        border-radius: 8px;
        color: #FFF8E1;
        font-size: 0.9rem;
        text-decoration: none;
        font-weight: 500;
        text-align: center;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
    }

    .btn.show {
        background: linear-gradient(135deg, #8D6E63 0%, #6D4C41 100%);
    }

    .btn.show:hover {
        background: linear-gradient(135deg, #6D4C41 0%, #5D4037 100%);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(141, 110, 99, 0.3);
    }

    .btn.edit {
        background: linear-gradient(135deg, #FFE0B2 0%, #F5DEB3 100%);
        color: #3E2723;
    }

    .btn.edit:hover {
        background: linear-gradient(135deg, #F5DEB3 0%, #FFE0B2 100%);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(245, 222, 179, 0.3);
    }

    /* Create Button */
    .create-btn {
        display: inline-block;
        background: linear-gradient(135deg, #3E2723 0%, #4E342E 100%);
        color: #FFF8E1;
        font-weight: 600;
        padding: 12px 28px;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(62, 39, 35, 0.3);
        border: none;
        cursor: pointer;
        font-size: 1rem;
    }

    .create-btn:hover {
        background: linear-gradient(135deg, #4E342E 0%, #5D4037 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(62, 39, 35, 0.4);
    }

    /* No Products State */
    .no-products {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 20px;
        color: #8D6E63;
    }

    .no-products i {
        font-size: 4rem;
        margin-bottom: 20px;
        opacity: 0.3;
    }

    .no-products p {
        font-size: 1.2rem;
        margin-bottom: 25px;
    }

    /* Responsive */
    @media (max-width: 1200px) {
        .products-grid {
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
        }
    }

    @media (max-width: 768px) {
        .inventory-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }

        .inventory-header h1 {
            font-size: 1.6rem;
        }

        .products-grid {
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 15px;
        }

        .product-info {
            padding: 15px;
        }

        .product-name {
            font-size: 1rem;
        }

        .product-price {
            font-size: 1.1rem;
        }
    }

    @media (max-width: 480px) {
        .products-grid {
            grid-template-columns: 1fr;
        }

        .product-actions {
            flex-direction: column;
        }

        .btn {
            width: 100%;
        }
    }
</style>

<script>
    // Optional: Add favorite functionality
    document.addEventListener('DOMContentLoaded', function() {
        const favBtns = document.querySelectorAll('.favorite-btn');
        
        favBtns.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                this.classList.toggle('active');
                const icon = this.querySelector('i');
                
                if (this.classList.contains('active')) {
                    icon.classList.remove('far');
                    icon.classList.add('fas');
                } else {
                    icon.classList.remove('fas');
                    icon.classList.add('far');
                }
            });
        });
    });
</script>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Restock - {{ product.name }}{% endblock %}

{% block body %}
<div style="max-width: 700px; margin: 0 auto; padding: 25px 10px;">
    <h1 style="color: #8B5E3C; margin-bottom: 12px;">
        Restock: {{ product.name }}
    </h1>
    <p style="color: #6a6a6a; margin-bottom: 22px;">
        Current stock: <strong style="color: #2E7D32;">{{ product.stock }}</strong>
    </p>

    {% for message in app.flashes('error') %}
        <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: 12px; margin-bottom: 18px; border-left: 4px solid #dc3545; font-weight: 600;">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('success') %}
        <div style="background: #d4edda; color: #155724; padding: 12px; border-radius: 12px; margin-bottom: 18px; border-left: 4px solid #28a745; font-weight: 600;">
            {{ message }}
        </div>
    {% endfor %}

    <form method="post" style="display: grid; grid-template-columns: 1fr; gap: 14px;">
        <div>
            <label style="display: block; margin-bottom: 6px; color: #555; font-weight: 700;" for="amount">
                Amount to add
            </label>
            <input
                id="amount"
                name="amount"
                type="number"
                min="1"
                step="1"
                required
                style="width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 12px; font-size: 1rem;"
            >
        </div>

        <input type="hidden" name="_token" value="{{ csrf_token('restock' ~ product.id) }}">

        <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 6px;">
            <button
                type="submit"
                style="flex: 1; min-width: 200px; padding: 14px 18px; background: linear-gradient(135deg, #FFB300 0%, #FB8C00 100%); color: white; border: none; border-radius: 12px; font-size: 1.05rem; font-weight: 900; cursor: pointer;"
            >
                Restock
            </button>

            <a
                href="{{ path('app_product_show', {'id': product.id}) }}"
                style="flex: 1; min-width: 200px; text-align: center; padding: 14px 18px; background: #ffffff; border: 2px solid rgba(139, 94, 60, 0.15); color: #8B5E3C; border-radius: 12px; text-decoration: none; font-size: 1.05rem; font-weight: 800;"
            >
                Back
            </a>
        </div>
    </form>
</div>
{% endblock %}

